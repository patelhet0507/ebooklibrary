generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String
  phone     String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  xp        Int      @default(0)
  level     Int      @default(1)
  newsletter Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  books        Book[]
  transactions Transaction[]
  fines        Fine[]
  commissions  Commission[]
  payments     Payment[]
  reviews      Review[]
  wishlist     Wishlist[]
  coupons      CouponUsage[]
  notifications Notification[]
  sellerVerification SellerVerification?

  @@index([role])
  @@index([role, created_at])
  @@map("users")
}

model SellerVerification {
  id            String   @id @default(uuid())
  seller_id     String   @unique
  business_name String
  gstin         String?
  phone         String
  address       String?
  city          String?
  state         String?
  pincode       String?
  status        String   @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  rejection_reason String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  seller User @relation(fields: [seller_id], references: [id], onDelete: Cascade)

  @@map("seller_verifications")
}

model Book {
  id                String   @id @default(uuid())
  title             String
  author            String
  isbn              String?  @unique
  slug              String?  @unique
  description       String?
  language          String?
  genre            String?
  cover_image       String?
  content_url       String?
  price             Float
  rental_price_per_day Float?
  stock             Int      @default(0)
  seller_id         String?
  avg_rating        Float    @default(0)
  review_count      Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  seller       User?        @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  transactions Transaction[]
  reviews      Review[]
  images       BookImage[]
  wishlist     Wishlist[]

  @@index([seller_id])
  @@index([price])
  @@index([avg_rating])
  @@index([review_count])
  @@index([created_at])
  @@index([language])
  @@index([genre])
  @@map("books")
}

model BookImage {
  id         String   @id @default(uuid())
  book_id    String
  url        String
  is_primary Boolean  @default(false)
  created_at DateTime @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([book_id])
  @@index([book_id, is_primary])
  @@map("book_images")
}

model Transaction {
  id                  String   @id @default(uuid())
  book_id             String
  customer_id         String
  type                String
  quantity            Int      @default(1)
  rental_days         Int?
  total_amount        Float
  due_date            DateTime?
  returned_at         DateTime?
  return_requested_at DateTime?
  refund_reason       String?
  coupon_id           String?
  created_at          DateTime @default(now())

  book           Book      @relation(fields: [book_id], references: [id], onDelete: Cascade)
  customer       User      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  fines          Fine[]
  payment        Payment?
  coupon         Coupon?   @relation(fields: [coupon_id], references: [id], onDelete: SetNull)
  couponUsages   CouponUsage[]

  @@index([book_id])
  @@index([customer_id])
  @@index([coupon_id])
  @@index([type])
  @@index([type, created_at])
  @@index([type, customer_id])
  @@index([type, return_requested_at, returned_at])
  @@map("transactions")
}

model Fine {
  id             String    @id @default(uuid())
  transaction_id String
  user_id        String
  amount         Float
  days_late      Int
  status         String    @default("PENDING")
  created_at     DateTime  @default(now())
  paid_at        DateTime?

  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([transaction_id])
  @@index([user_id])
  @@index([status])
  @@index([status, created_at])
  @@index([user_id, created_at])
  @@map("fines")
}

model Commission {
  id          String   @id @default(uuid())
  seller_id   String
  amount      Float
  percentage  Float
  description String?
  created_at  DateTime @default(now())

  seller User @relation(fields: [seller_id], references: [id], onDelete: Cascade)

  @@index([seller_id])
  @@index([seller_id, created_at])
  @@map("commissions")
}

model Payment {
  id               String   @id @default(uuid())
  transaction_id   String   @unique
  user_id          String
  method           String
  amount           Float
  status           String   @default("PENDING")
  upi_id           String?
  bank_name        String?
  account_number   String?
  ifsc_code        String?
  delivery_name    String?
  delivery_phone   String?
  delivery_address String?
  created_at       DateTime @default(now())

  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, created_at])
  @@map("payments")
}

model Review {
  id         String   @id @default(uuid())
  book_id    String
  user_id    String
  rating     Int
  comment    String?
  created_at DateTime @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([book_id])
  @@index([user_id])
  @@index([book_id, user_id])
  @@index([book_id, created_at])
  @@map("reviews")
}

model Wishlist {
  id        String   @id @default(uuid())
  user_id   String
  book_id   String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@unique([user_id, book_id])
  @@index([user_id])
  @@index([book_id])
  @@map("wishlist")
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  description     String?
  discount_type   String   // "PERCENTAGE" | "FIXED"
  discount_value  Float
  min_order_amount Float   @default(0)
  max_discount     Float?
  usage_limit     Int      @default(1)
  used_count      Int      @default(0)
  valid_from      DateTime @default(now())
  valid_until     DateTime?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  usages       CouponUsage[]
  transactions Transaction[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  coupon_id String
  user_id   String
  transaction_id String?
  created_at DateTime @default(now())

  coupon Coupon @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)

  @@unique([coupon_id, user_id])
  @@index([coupon_id])
  @@index([user_id])
  @@index([transaction_id])
  @@map("coupon_usages")
}

model Notification {
  id        String   @id @default(uuid())
  user_id   String
  type      String   // "DUE_DATE" | "NEW_RELEASE" | "RETURN_APPROVED" | "RETURN_REJECTED" | "FINE_CREATED" | "GENERAL"
  title     String
  message   String
  data      String?  // JSON for additional data
  is_read   Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@index([user_id, is_read, created_at])
  @@index([user_id, created_at])
  @@map("notifications")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event_type String  // "VIEW" | "PURCHASE" | "RENT" | "SEARCH" | "WISHLIST_ADD" | "COUPON_USE"
  user_id   String?
  book_id   String?
  data      String?  // JSON
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([book_id])
  @@index([event_type])
  @@index([event_type, created_at])
  @@map("analytics_events")
}